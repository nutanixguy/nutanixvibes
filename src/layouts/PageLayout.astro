---
import Layout from './Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import { SITE_CONFIG, getAssetUrl } from '../config';

interface Props {
  title: string;
  cover?: string | null;
  description?: string;
  subclass?: string;
}

const { title, cover, description, subclass } = Astro.props;
---

<Layout
  title={title}
  description={description}
  image={cover}
  current="page"
>
    <!-- Page Header -->
    <header class="site-header outer">
        <div class="inner">
            <SiteNav current="page" />
        </div>
    </header>

    <!-- Main Content Area -->
    <main id="site-main" class="site-main outer" role="main">
        <div class="inner">
            <article class={`post-full ${subclass || ''} ${!cover ? 'no-image' : ''}`}>
                <header class="post-full-header">
                    <h1 class="post-full-title">{title}</h1>
                </header>

                {cover && (
                    <figure class="post-full-image page-hero-image">
                        <img
                            src={getAssetUrl(cover)}
                            alt={title}
                            loading="eager"
                            fetchpriority="high"
                        />
                    </figure>
                )}

                <section class="post-full-content">
                    <div class="kg-card-markdown">
                        <slot />
                    </div>
                </section>
            </article>
        </div>
    </main>
</Layout>


