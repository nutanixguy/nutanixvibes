---
import BaseHead from '../components/BaseHead.astro';
import SubscribeModal from '../components/SubscribeModal.astro';
import { SITE_CONFIG, getAssetUrl } from '../config';
import { ClientRouter } from 'astro:transitions';

// Import CSS stylesheets so Astro bundles them
import '../styles/global.css';
import '../styles/screen.css';

interface Props {
  title?: string;
  description?: string;
  image?: string | null;
  type?: 'website' | 'article';
  articleDate?: string | Date;
  tags?: string[];
  author?: string;
  current?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  articleDate,
  tags = [],
  author,
  current,
} = Astro.props;

const currentYear = new Date().getFullYear();
const bodyClass = current === 'home' ? 'home-template' : `${current || 'page'}-template`;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      articleDate={articleDate}
      tags={tags}
      author={author}
    />
    <script is:inline>
        // Theme toggle script to prevent FOUC
        (function() {
            var currentTheme = localStorage.getItem('theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (currentTheme === 'dark' || (!currentTheme && prefersDark)) {
                document.documentElement.classList.add('dark-mode');
                document.documentElement.classList.remove('light-mode');
            } else {
                document.documentElement.classList.add('light-mode');
                document.documentElement.classList.remove('dark-mode');
            }
        })();

        // Re-run theme check on page transitions
        document.addEventListener('astro:after-swap', function() {
            var currentTheme = localStorage.getItem('theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (currentTheme === 'dark' || (!currentTheme && prefersDark)) {
                document.documentElement.classList.add('dark-mode');
                document.documentElement.classList.remove('light-mode');
            } else {
                document.documentElement.classList.add('light-mode');
                document.documentElement.classList.remove('dark-mode');
            }
        });
    </script>
    <ClientRouter />
</head>
<body class={bodyClass}>
    <div class="site-wrapper">
        <!-- Main Content Slot -->
        <slot />

        <!-- Footer -->
        <footer class="site-footer outer">
            <div class="site-footer-content inner">
                <section class="copyright">
                    <a href={getAssetUrl('/')}>{SITE_CONFIG.title}</a> &copy; {currentYear}
                </section>
                <section class="poweredby">
                    Infrastructure notes by Jamie Terrell
                </section>
                <nav class="site-footer-nav">
                    <a href={getAssetUrl('/')}>Latest Posts</a>
                    <a href={getAssetUrl('/about/')}>About</a>
                    <a href={getAssetUrl('/feed.xml')}>RSS</a>
                    {SITE_CONFIG.xUsername ? (
                        <a href={`https://x.com/${SITE_CONFIG.xUsername}`} target="_blank" rel="noopener">X</a>
                    ) : SITE_CONFIG.twitter && (
                        <a href={`https://twitter.com/${SITE_CONFIG.twitter}`} target="_blank" rel="noopener">Twitter</a>
                    )}
                    {SITE_CONFIG.linkedin && (
                        <a href={SITE_CONFIG.linkedin} target="_blank" rel="noopener">LinkedIn</a>
                    )}
                    {SITE_CONFIG.github && (
                        <a href={`https://github.com/${SITE_CONFIG.github}`} target="_blank" rel="noopener">GitHub</a>
                    )}
                    {SITE_CONFIG.email && (
                        <a href={`mailto:${SITE_CONFIG.email}`}>Email</a>
                    )}
                </nav>
            </div>
        </footer>
    </div>

    <!-- Subscribe Modal overlay -->
    {SITE_CONFIG.subscribers && <SubscribeModal />}
</body>
</html>
