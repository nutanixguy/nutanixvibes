---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import PostCard from '../components/PostCard.astro';
import AlgoliaSearch from '../components/AlgoliaSearch.astro';
import { SITE_CONFIG, getAssetUrl } from '../config';

export async function getStaticPaths({ paginate }: any) {
  const allPosts = await getCollection('posts');
  allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  
  const pages = paginate(allPosts, { pageSize: SITE_CONFIG.pageSize });
  
  return pages.map((p: any) => ({
    params: { 
      page: p.params.page === 1 || p.params.page === '1' || !p.params.page ? undefined : `page${p.params.page}` 
    },
    props: { 
      pageProps: p.props,
      maxPages: pages.length
    }
  }));
}

const { pageProps, maxPages } = Astro.props;
const { page } = pageProps;

// Determine header image
const headerBg = SITE_CONFIG.cover ? getAssetUrl(SITE_CONFIG.cover) : null;
---

<Layout current="home">
    <!-- Header -->
    <header class={`site-header outer ${headerBg ? '' : 'no-cover'}`} style={headerBg ? `background-image: url(${headerBg})` : ''}>
        <div class="inner">
            <div class="site-header-content">
                <h1 class="site-title">
                    {SITE_CONFIG.logo ? (
                        <img class="site-logo" src={getAssetUrl(SITE_CONFIG.logo)} alt={SITE_CONFIG.title}/>
                    ) : (
                        SITE_CONFIG.title
                    )}
                </h1>
                <h2 class="site-description">{SITE_CONFIG.description}</h2>
            </div>
            <SiteNav current="home" />
        </div>
    </header>

    <!-- Main Content Feed -->
    <main id="site-main" class="site-main outer" role="main">
        <div class="inner">
            {SITE_CONFIG.algolia && (
                <div id="search-hits" class="post-feed" style="display: none;"></div>
            )}
            
            <div id="posts" class="post-feed" data-max-pages={maxPages} data-base-url={getAssetUrl('/')}>
                {page.data.map((post: any) => (
                    <PostCard post={post} />
                ))}
            </div>

            {SITE_CONFIG.algolia && <AlgoliaSearch />}
        </div>
    </main>
</Layout>

<script>
  import { initInfiniteScroll } from '../utils/infinite-scroll';
  document.addEventListener('astro:page-load', () => {
    initInfiniteScroll('#posts');
  });
</script>


