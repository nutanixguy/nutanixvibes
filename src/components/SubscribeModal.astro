---
import SubscribeForm from './SubscribeForm.astro';
import { SITE_CONFIG, getAssetUrl } from '../config';
---

{SITE_CONFIG.subscribers && (
  <div id="subscribe" class="subscribe-overlay">
      <a class="subscribe-overlay-close" href="#"></a>
      <div class="subscribe-overlay-content">
          {SITE_CONFIG.logo && (
              <img class="subscribe-overlay-logo" src={getAssetUrl(SITE_CONFIG.logo)} alt={SITE_CONFIG.title} />
          )}
          <h1 class="subscribe-overlay-title">Subscribe to {SITE_CONFIG.title}</h1>
          <p class="subscribe-overlay-description">Stay up to date! Get all the latest &amp; greatest posts delivered straight to your inbox</p>
          <SubscribeForm placeholder="youremail@example.com" />
      </div>
  </div>
)}

<script>
  // Script to handle closing the subscribe overlay when close button is clicked
  document.addEventListener('astro:page-load', () => {
    const closeBtn = document.querySelector('.subscribe-overlay-close');
    const overlay = document.querySelector('.subscribe-overlay');
    if (closeBtn && overlay) {
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        overlay.classList.remove('subscribe-overlay-active');
        window.location.hash = '';
      });

      // Show/hide based on hash change
      const checkHash = () => {
        if (window.location.hash === '#subscribe') {
          overlay.classList.add('subscribe-overlay-active');
        } else {
          overlay.classList.remove('subscribe-overlay-active');
        }
      };

      window.addEventListener('hashchange', checkHash);
      checkHash();

      const cleanup = () => {
        window.removeEventListener('hashchange', checkHash);
        document.removeEventListener('astro:before-swap', cleanup);
      };
      document.addEventListener('astro:before-swap', cleanup);
    }
  });
</script>
