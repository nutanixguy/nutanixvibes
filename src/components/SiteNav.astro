---
import Navigation from './Navigation.astro';
import { SITE_CONFIG, getAssetUrl } from '../config';
import Facebook from './icons/Facebook.astro';
import Twitter from './icons/Twitter.astro';
import X from './icons/X.astro';
import Github from './icons/Github.astro';
import LinkedIn from './icons/LinkedIn.astro';
import Search from './icons/Search.astro';
import Sun from './icons/Sun.astro';
import Moon from './icons/Moon.astro';

interface Props {
  current?: string;
}

const { current } = Astro.props;
const showLogo = current !== 'home';
---

<nav class="site-nav">
    <div class="site-nav-left">
        {showLogo && (
            SITE_CONFIG.logo ? (
                <a class="site-nav-logo" href={getAssetUrl('/')}>
                    <img src={getAssetUrl(SITE_CONFIG.logo)} alt={SITE_CONFIG.title} />
                </a>
            ) : (
                <a class="site-nav-logo" href={getAssetUrl('/')}>{SITE_CONFIG.title}</a>
            )
        )}
        {SITE_CONFIG.navigation && <Navigation />}
    </div>
    <div class="site-nav-right">
        {SITE_CONFIG.algolia && (
            current === 'home' ? (
                <div id="search-searchbar" style="margin-right: 15px;"></div>
                <div class="social-link social-link-search" style="cursor: pointer; margin-right: 15px;" aria-label="Search">
                    <Search style="width:16px;height:16px;" />
                </div>
            ) : (
                <a class="social-link social-link-search" href={getAssetUrl('/?search=true')} style="margin-right: 15px;" aria-label="Search">
                    <Search style="width:16px;height:16px;" />
                </a>
            )
        )}
        
        <div class="social-links">
            {SITE_CONFIG.facebook && (
                <a class="social-link social-link-fb" href={`https://facebook.com/${SITE_CONFIG.facebook}`} target="_blank" rel="noopener" aria-label="Facebook">
                    <Facebook />
                </a>
            )}
            {SITE_CONFIG.xUsername ? (
                <a class="social-link social-link-tw" href={`https://x.com/${SITE_CONFIG.xUsername}`} target="_blank" rel="noopener" aria-label="X">
                    <X style="width:16px;height:16px;" />
                </a>
            ) : SITE_CONFIG.twitter && (
                <a class="social-link social-link-tw" href={`https://twitter.com/${SITE_CONFIG.twitter}`} target="_blank" rel="noopener" aria-label="Twitter">
                    <Twitter style="width:16px;height:16px;" />
                </a>
            )}
            {SITE_CONFIG.github && (
                <a class="social-link social-link-gh" href={`https://github.com/${SITE_CONFIG.github}`} target="_blank" rel="noopener" aria-label="GitHub">
                    <Github style="width:16px;height:16px;" />
                </a>
            )}
            {SITE_CONFIG.linkedin && (
                <a class="social-link social-link-li" href={SITE_CONFIG.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
                    <LinkedIn style="width:16px;height:16px;" />
                </a>
            )}
            {SITE_CONFIG.email && (
                <a class="social-link social-link-mail" href={`mailto:${SITE_CONFIG.email}`} aria-label="Email">
                    @
                </a>
            )}
        </div>
        
        {(SITE_CONFIG.facebook || SITE_CONFIG.twitter || SITE_CONFIG.xUsername || SITE_CONFIG.github || SITE_CONFIG.linkedin || SITE_CONFIG.email) && (
            <span class="nav-divider" style="display: inline-block; width: 1px; height: 16px; background: rgba(255, 255, 255, 0.3); margin: 0 5px 0 10px;"></span>
        )}

        <a class="social-link theme-toggle" href="#" style="cursor: pointer; margin-right: 10px;" title="Toggle Theme" aria-label="Toggle Theme">
            <Moon class="icon-moon" style="height: 1.8rem; overflow: visible;" />
            <Sun class="icon-sun" style="display: none; height: 1.8rem; overflow: visible;" />
        </a>

        {SITE_CONFIG.subscribers && (
            <a class="subscribe-button" href="#subscribe">Subscribe</a>
        )}
    </div>
</nav>

<script>
  const setupThemeToggle = () => {
    const html = document.documentElement;
    const toggles = document.querySelectorAll('.theme-toggle');
    
    const updateIcons = () => {
      const isDark = html.classList.contains('dark-mode');
      document.querySelectorAll('.icon-moon').forEach((el) => {
        (el as HTMLElement).style.display = isDark ? 'none' : 'block';
      });
      document.querySelectorAll('.icon-sun').forEach((el) => {
        (el as HTMLElement).style.display = isDark ? 'block' : 'none';
      });
    };

    updateIcons();

    toggles.forEach((toggle) => {
      // Setup click handler
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        const isDark = html.classList.contains('dark-mode');
        if (isDark) {
          html.classList.remove('dark-mode');
          html.classList.add('light-mode');
          localStorage.setItem('theme', 'light');
        } else {
          html.classList.remove('light-mode');
          html.classList.add('dark-mode');
          localStorage.setItem('theme', 'dark');
        }
        updateIcons();
      });
    });
  };

  document.addEventListener('astro:page-load', setupThemeToggle);
</script>
