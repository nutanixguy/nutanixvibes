---
interface Props {
  class?: string;
  style?: string;
  [key: string]: any;
}
const { class: className, style, ...rest } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  class={className}
  style={style}
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  {...rest}
>
  <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
</svg>
