---
import { SITE_CONFIG, getAssetUrl } from '../config';
import HandPoint from './icons/HandPoint.astro';
import X from './icons/X.astro';
import Facebook from './icons/Facebook.astro';
import LinkedIn from './icons/LinkedIn.astro';

interface Props {
  title: string;
  slug: string;
}

const { title, slug } = Astro.props;

// Absolute canonical URL of the post for sharing
const siteUrl = Astro.site ? Astro.site.toString() : 'https://casper.leons.dev/';
const postUrl = new URL(getAssetUrl(`/${slug}/`), siteUrl).toString();
---

<div class="floating-header">
    <div class="floating-header-logo">
        <a href={getAssetUrl('/')}>
            {SITE_CONFIG.logoDark && (
                <img src={getAssetUrl(SITE_CONFIG.logoDark)} alt={`${SITE_CONFIG.title} icon`} />
            )}
            <span>{SITE_CONFIG.title}</span>
        </a>
    </div>
    <span class="floating-header-divider">&mdash;</span>
    <div class="floating-header-title">{title}</div>
    <div class="floating-header-share">
        <div class="floating-header-share-label">
            Share this 
            <HandPoint class="point-icon" style="width:18px;height:18px;display:inline-block;vertical-align:middle;margin-left:4px;" />
        </div>
        <a class="floating-header-share-x" href={`https://x.com/intent/post?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`}
            onclick="window.open(this.href, 'share-x', 'width=550,height=235');return false;">
            <X style="width:16px;height:16px;" />
        </a>
        <a class="floating-header-share-fb" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`}
            onclick="window.open(this.href, 'share-facebook','width=580,height=296');return false;">
            <Facebook style="width:16px;height:16px;" />
        </a>
        <a class="floating-header-share-li" href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(postUrl)}&title=${encodeURIComponent(title)}`}
            onclick="window.open(this.href, 'share-linkedin', 'width=580,height=496');return false;">
            <LinkedIn style="width:16px;height:16px;" />
        </a>
    </div>

    <progress class="progress" value="0">
        <div class="progress-container">
            <span class="progress-bar"></span>
        </div>
    </progress>
</div>
